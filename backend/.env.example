# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="Video Upload Platform"
# Set to true locally to enable /docs (Swagger UI) and verbose SQL logs
DEBUG=true
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_random_secret

# ── Database ───────────────────────────────────────────────────────────────────
# For local docker-compose: postgresql+asyncpg://postgres:postgres@db:5432/videodb
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/videodb

# ── Alibaba Cloud OSS ──────────────────────────────────────────────────────────
OSS_ACCESS_KEY_ID=your_access_key_id
OSS_ACCESS_KEY_SECRET=your_access_key_secret
OSS_BUCKET_NAME=platform-eng-1
# Use external endpoint for local dev; internal endpoint when running inside Alibaba Cloud VPC
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_INTERNAL_ENDPOINT=

# ── Upload settings ────────────────────────────────────────────────────────────
DEFAULT_CHUNK_SIZE_BYTES=10485760   # 10 MB
UPLOAD_SESSION_TTL_HOURS=24

# ── CORS ───────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost"]
